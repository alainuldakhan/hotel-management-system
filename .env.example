# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=hotel_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Backend ───────────────────────────────────────────────────────────────────
# Override appsettings.json values via environment variables
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=hotel_management;Username=postgres;Password=postgres

JwtSettings__SecretKey=change-this-to-a-long-random-secret-key-min-32chars

# Gmail SMTP (create an App Password at https://myaccount.google.com/apppasswords)
EmailSettings__IsEnabled=false
EmailSettings__SmtpUsername=your-gmail@gmail.com
EmailSettings__SmtpPassword=your-gmail-app-password
EmailSettings__FromEmail=your-gmail@gmail.com

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=/api
